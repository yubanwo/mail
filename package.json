{
  "name": "mail-worker",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "deploy": "vite build && wrangler deploy",
    "db:migrate:local": "wrangler d1 execute mail --local --file=./migrations/0001_initial.sql",
    "db:migrate:remote": "wrangler d1 execute mail --remote --file=./migrations/0001_initial.sql",
    "check": "node --check src/worker/index.js"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "hono": "^4.12.23",
    "jose": "^6.2.3",
    "lucide-react": "^1.17.0",
    "postal-mime": "^2.7.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.39.2",
    "@cloudflare/workers-types": "^4.20260602.1",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.16",
    "wrangler": "^4.97.0"
  }
}
